{
  "rewrites": [
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "s" },
        { "type": "header", "key": "user-agent", "value": ".*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Discordbot|Googlebot|LinkedInBot|whatsapp).* " }
      ],
      "destination": "/api/og"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
